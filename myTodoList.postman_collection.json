              "pm.collectionVariables.set(\"eventId\", String(res.id).trim());\r",
              "pm.test(\"event created, eventId saved\", () => {\r",
              "    pm.expect(res.id).to.be.a(\"string\").and.not.empty;\r",
              "    pm.expect(res.category).to.eql(\"WORK\");\r",
              "    pm.expect(res.status).to.eql(\"PUBLISHED\");\r",
              "});"
