    {
      "name": "registerUser",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();\r",
              "if (res.id) {\r",
              "    pm.collectionVariables.set(\"userId\", String(res.id).trim());\r",
              "    pm.test(\"registered, userId saved\", () => {\r",
              "        pm.expect(res.id).to.be.a(\"string\").and.not.empty;\r",
              "    });\r",
              "} else {\r",
              "    pm.test(\"username already exists (expected on re-run)\", () => {\r",
              "        pm.expect(res.message).to.include(\"already exists\");\r",
              "    });\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"username\": \"john\",\r\n  \"password\": \"123456\",\r\n  \"email\": \"test@test.com\",\r\n  \"name\": \"myname\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
